{
  "compilerOptions": {
    "target": "ES2019",
    "module": "node16",
    "jsx": "react-jsx",
    "declaration": true,
    "ignoreDeprecations": "6.0",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}
