{
  "name": "tiktok-pixel",
  "version": "1.0.0",
  "description": "React + Next.js TikTok Pixel SDK (client-first root + server entry)",
  "license": "MIT",
  "author": "Md Asikuzzaman",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.cjs",
      "default": "./dist/server.mjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.cjs",
      "default": "./dist/client.mjs"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "server": [
        "dist/server.d.ts"
      ],
      "client": [
        "dist/client.d.ts"
      ],
      "*": [
        "dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "keywords": [
    "react",
    "next",
    "tiktok",
    "analytics",
    "pixel",
    "nextjs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/md-asikuzzaman/tiktok-pixel"
  },
  "bugs": {
    "url": "https://github.com/md-asikuzzaman/tiktok-pixel/issues"
  },
  "homepage": "https://github.com/md-asikuzzaman/tiktok-pixel#readme",
  "peerDependencies": {
    "next": ">=16.0.0 <17",
    "react": ">=18.0.0 <20",
    "react-dom": ">=18.0.0 <20"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.10",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "next": "^16.2.6",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3"
  }
}
